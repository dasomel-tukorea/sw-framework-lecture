<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
  [복사 위치] src/main/resources/mapper/StudentMapper.xml
  [작업] Week 11 lab02 — 학생 검색 + 정렬 + 페이징 통합
         lab01 의 StudentMapper.xml 을 본 파일 내용으로 교체한다 (namespace 충돌 방지).

  핵심 학습 포인트:
  - ORDER BY 위치에는 #{} 바인딩이 들어가지 못한다
    (PreparedStatement '?' → 문자열 리터럴이 되어 정렬이 동작하지 않음).
  - ${sortBy} 로 쓰면 SQL Injection 위험 → <choose> 화이트리스트로 컬럼명을 분기한다.
  - lab01 의 <sql id="studentColumns"> / <sql id="searchCondition"> 을 그대로 재사용.

  resultType="Student" / parameterType="PageDTO" 는
  mybatis.type-aliases-package 에 등록된 패키지에서 별칭이 해석된다.
-->
<mapper namespace="kr.ac.tukorea.swframework.mapper.StudentMapper">

    <!-- ============================================ -->
    <!-- 공통 컬럼 (SELECT 재사용용)                    -->
    <!-- ============================================ -->
    <sql id="studentColumns">
        id, name, student_id, email, major, created_at
    </sql>

    <!-- ============================================ -->
    <!-- 공통 검색 조건 (lab01 과 동일 — W10 lab04 4종) -->
    <!-- ============================================ -->
    <sql id="searchCondition">
        <where>
            <if test="searchType == 'name' and keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="searchType == 'email' and keyword != null and keyword != ''">
                AND email LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="searchType == 'student_id' and keyword != null and keyword != ''">
                AND student_id LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="searchType == 'major' and keyword != null and keyword != ''">
                AND major LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </sql>

    <!-- ============================================ -->
    <!-- 학생 목록: 검색 + 정렬 + 페이징 (lab01 확장)   -->
    <!--                                              -->
    <!-- <choose> 로 sortBy 화이트리스트 분기:          -->
    <!--   name | student_id | major | created_at     -->
    <!-- 그 외 값(또는 null)은 <otherwise> 의 기본 정렬 -->
    <!-- ============================================ -->
    <select id="findAllWithPaging" parameterType="PageDTO" resultType="Student">
        SELECT <include refid="studentColumns"/>
        FROM student
        <include refid="searchCondition"/>
        ORDER BY
        <choose>
            <when test="sortBy == 'name'">name ASC</when>
            <when test="sortBy == 'student_id'">student_id ASC</when>
            <when test="sortBy == 'major'">major ASC</when>
            <when test="sortBy == 'created_at'">created_at DESC</when>
            <otherwise>id DESC</otherwise>  <!-- 기본값: 최신 등록순 -->
        </choose>
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- ============================================ -->
    <!-- 전체 학생 수 (검색 조건 반영, 페이지 수 계산용) -->
    <!-- 정렬은 COUNT 에 영향이 없으므로 ORDER BY 없음   -->
    <!-- ============================================ -->
    <select id="countAll" parameterType="PageDTO" resultType="int">
        SELECT COUNT(*) FROM student
        <include refid="searchCondition"/>
    </select>

    <!-- ============================================ -->
    <!-- 학생 상세 / 등록 / 수정 / 삭제                  -->
    <!-- (lab01 과 동일 — 별도 파일로 분리하지 않으면     -->
    <!--  본 파일에 함께 포함시켜 namespace 일관성 유지)  -->
    <!-- ============================================ -->
    <select id="findById" parameterType="long" resultType="Student">
        SELECT <include refid="studentColumns"/>
        FROM student
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Student" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student (name, student_id, email, major)
        VALUES (#{name}, #{studentId}, #{email}, #{major})
    </insert>

    <update id="update" parameterType="Student">
        UPDATE student
        SET name       = #{name},
            student_id = #{studentId},
            email      = #{email},
            major      = #{major}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM student WHERE id = #{id}
    </delete>

</mapper>
