### [Lab01-1] 1페이지 (기본) — size=10 가정, 10명 노출
GET {{baseUrl}}/students
Accept: text/html

> {%
client.test("상태코드 200", () => client.assert(response.status === 200));
client.test("학생 목록 페이지", () => client.assert(response.body.includes("학생")));
%}

###

### [Lab01-2] 1페이지 명시 — page=1&size=10
GET {{baseUrl}}/students?page=1&size=10
Accept: text/html

> {%
client.test("1페이지 200", () => client.assert(response.status === 200));
client.test("페이지네이션 UI 존재", () =>
    client.assert(response.body.includes("page=") ||
                  response.body.includes("페이지")));
%}

###

### [Lab01-3] 2페이지 — OFFSET=10 (11~20번 학생)
GET {{baseUrl}}/students?page=2&size=10
Accept: text/html

> {%
