# ══════════════════════════════════════════════════════════════
# Lab 04 — 파일 업로드/다운로드 (MultipartFile + UUID)
# ══════════════════════════════════════════════════════════════
### IntelliJ HTTP Client multipart 문법:
###   < ./fixtures/sample.txt  로 디스크 파일을 바이너리로 첨부.
### 사전 준비:
###   week11/fixtures/sample.txt 를 만들거나, 아래 inline 데이터 형태로 그대로 실행 가능.

### [Lab04-1] 첨부 없이 정상 등록 (회귀 — Lab01 시나리오)
# @no-redirect
POST {{baseUrl}}/students
Content-Type: application/x-www-form-urlencoded

name=박지성&studentId=202311004&email=park@tukorea.ac.kr&major=IT경영

> {%
client.test("등록 후 redirect", () =>
    client.assert([302, 303].includes(response.status)));
const loc = response.headers.valueOf("Location");
const m = loc && loc.match(/\/students\/(\d+)$/);
if (m) client.global.set("newStudentId", m[1]);
%}

###

### [Lab04-2] 첨부와 함께 등록 (multipart/form-data)
###   학생증.pdf 형태로 attachment_name 저장, UUID 가 saved_name 에 저장
# @no-redirect
POST {{baseUrl}}/students
Content-Type: multipart/form-data; boundary=----W11Boundary

------W11Boundary
Content-Disposition: form-data; name="name"

손흥민
------W11Boundary
Content-Disposition: form-data; name="studentId"

202311005
------W11Boundary
Content-Disposition: form-data; name="email"

son@tukorea.ac.kr
------W11Boundary
Content-Disposition: form-data; name="major"

IT경영
------W11Boundary
Content-Disposition: form-data; name="attachment"; filename="학생증.txt"
Content-Type: text/plain

학생증 샘플 텍스트 — UUID 저장명과 원본명 분리 확인용
------W11Boundary--

> {%
client.test("multipart 등록 후 redirect", () =>
    client.assert([302, 303].includes(response.status)));
const loc = response.headers.valueOf("Location");
const m = loc && loc.match(/\/students\/(\d+)$/);
if (m) client.global.set("uploadedStudentId", m[1]);
%}

###

### [Lab04-3] 상세 페이지에 첨부 파일 다운로드 링크 노출 확인
GET {{baseUrl}}/students/{{uploadedStudentId}}
Accept: text/html

> {%
client.test("상세 200", () => client.assert(response.status === 200));
client.test("손흥민 표시", () => client.assert(response.body.includes("손흥민")));
client.test("첨부 다운로드 링크 표시", () =>
    client.assert(response.body.includes("attachment") ||
                  response.body.includes("다운로드") ||
                  response.body.includes("/students/attachment/")));
%}

###

### [Lab04-4] 금지 확장자 업로드 → 폼 재렌더링 또는 400
# @no-redirect
POST {{baseUrl}}/students
Content-Type: multipart/form-data; boundary=----W11Boundary

------W11Boundary
Content-Disposition: form-data; name="name"

악성업로드
------W11Boundary
Content-Disposition: form-data; name="studentId"

202311999
------W11Boundary
Content-Disposition: form-data; name="email"

bad@tukorea.ac.kr
------W11Boundary
Content-Disposition: form-data; name="major"

컴퓨터공학
------W11Boundary
Content-Disposition: form-data; name="attachment"; filename="evil.jsp"
Content-Type: application/octet-stream

<%@ page contentType="text/html" %>WEBSHELL
------W11Boundary--

> {%
client.test("확장자 차단 응답 도달", () =>
    client.assert([200, 302, 400, 415].includes(response.status)));
%}

###

# ══════════════════════════════════════════════════════════════
# Lab 05 — member 테이블 + BCrypt 회원가입/로그인 (W07 PasswordUtil 재사용)
# ══════════════════════════════════════════════════════════════

### [Lab05-1] 회원가입 폼
GET {{baseUrl}}/members/signup
Accept: text/html

> {%
client.test("가입 폼 200", () => client.assert(response.status === 200));
client.test("loginId input", () =>
    client.assert(response.body.includes('name="loginId"')));
client.test("password input", () =>
    client.assert(response.body.includes('name="password"')));
%}

###

### [Lab05-2] 정상 회원가입 → PRG redirect:/members/login
# @no-redirect
POST {{baseUrl}}/members/signup
Content-Type: application/x-www-form-urlencoded

loginId=newuser11&password=secret123&name=신규회원&email=new11@tukorea.ac.kr

> {%
client.test("가입 후 redirect", () =>
    client.assert([302, 303].includes(response.status)));
client.test("Location: /members/login", () =>
    client.assert(response.headers.valueOf("Location").endsWith("/members/login")));
%}

###

### [Lab05-3] 검증 실패 — 빈 아이디 → @NotBlank → 폼 재렌더링 (200)
POST {{baseUrl}}/members/signup
Content-Type: application/x-www-form-urlencoded

loginId=&password=secret123&name=홍&email=h@tukorea.ac.kr

> {%
client.test("검증 실패 → 폼 재렌더링 (200)", () =>
    client.assert(response.status === 200));
client.test("아이디 에러 메시지", () =>
    client.assert(response.body.includes("아이디") ||
                  response.body.includes("error")));
%}

###

### [Lab05-4] 검증 실패 — 짧은 비밀번호 (@Size min=6 위반)
POST {{baseUrl}}/members/signup
Content-Type: application/x-www-form-urlencoded

loginId=shortpw&password=123&name=짧은비번&email=s@tukorea.ac.kr

> {%
client.test("Size 검증 실패", () =>
    client.assert(response.status === 200));
client.test("비밀번호 에러 메시지", () =>
    client.assert(response.body.includes("비밀번호") ||
                  response.body.includes("6자")));
%}

###

### [Lab05-5] 회원 로그인 폼
GET {{baseUrl}}/members/login
Accept: text/html

> {%
